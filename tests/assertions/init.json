[
  {
    "name": "hands_off_to_auth_web",
    "type": "contains",
    "pattern": "auth\\.mjs[\\s\"']+web"
  },
  {
    "name": "checks_state_via_auth_status",
    "type": "contains",
    "pattern": "auth\\.mjs[\\s\"']+status"
  },
  {
    "name": "self_tests_via_auth_verify",
    "type": "contains",
    "pattern": "auth\\.mjs[\\s\"']+verify"
  },
  {
    "name": "explains_localhost_only",
    "type": "contains",
    "pattern": "127\\.0\\.0\\.1|localhost-only"
  },
  {
    "name": "warns_token_not_in_transcript",
    "type": "contains",
    "pattern": "transcript"
  },
  {
    "name": "has_iron_or_hard_rules_directive",
    "type": "contains",
    "pattern": "(?:iron|hard)\\s+rules?"
  },
  {
    "name": "tells_user_to_restart_claude_code",
    "type": "contains",
    "pattern": "Restart Claude Code"
  },
  {
    "name": "explains_missing_scope_recovery",
    "type": "contains",
    "pattern": "scopes? (?:added after creation|cannot have scopes added)"
  },
  {
    "name": "no_chat_form_paste_whichever",
    "type": "not_contains",
    "pattern": "Paste\\s+whichever"
  },
  {
    "name": "no_chat_form_please_provide_token",
    "type": "not_contains",
    "pattern": "please\\s+provide\\s+(?:your|the|what).{0,40}(?:token|credentials?)"
  },
  {
    "name": "no_chat_form_i_need_the_following",
    "type": "not_contains",
    "_comment": "The original failure transcript opened with 'I need the following'.",
    "pattern": "I\\s+need\\s+the\\s+following"
  },
  {
    "name": "no_numbered_credential_form",
    "type": "not_contains",
    "_comment": "Catches the bad numbered list of credential fields from the original failed transcript.",
    "pattern": "1\\.\\s*[^\\n]{0,80}(?:site URL|atlassian site)[\\s\\S]{0,300}\\n[\\s\\S]{0,40}2\\.\\s*[^\\n]{0,80}(?:email|account)[\\s\\S]{0,300}\\n[\\s\\S]{0,40}3\\.\\s*[^\\n]{0,80}(?:API token|credential)",
    "dotall": true
  },
  {
    "name": "no_ask_user_to_paste_in_chat",
    "type": "not_contains",
    "_comment": "Anchored to start-of-sentence. Negations like 'never ask the user to paste...' are mid-sentence and don't match.",
    "pattern": "(?:^|\\.\\s+|\\n\\s*)Paste[^.\\n]{0,30}(?:token|credentials?|api[\\s-]?key)[^.\\n]{0,40}(?:here|in (?:the )?chat|in (?:the )?message)"
  },
  {
    "name": "no_walk_you_through_setup_prose",
    "type": "not_contains",
    "pattern": "I'll walk you through setup"
  },
  {
    "name": "frontmatter_allows_Bash",
    "type": "frontmatter_contains",
    "field": "allowed-tools",
    "value": "Bash"
  },
  {
    "name": "frontmatter_does_not_allow_AskUserQuestion",
    "type": "frontmatter_not_contains",
    "_comment": "Init hands off to the web wizard for credentials. Other skills are free to use AskUserQuestion in their own frontmatter — this only constrains init.",
    "field": "allowed-tools",
    "value": "AskUserQuestion"
  },
  {
    "name": "frontmatter_does_not_allow_configure_credentials",
    "type": "frontmatter_not_contains",
    "_comment": "The wizard's /save endpoint persists directly via auth.mjs atomic-write. Allowing the MCP configure tool here would create a parallel write path.",
    "field": "allowed-tools",
    "value": "mcp__acendas-atlassian__configure_credentials"
  },
  {
    "name": "auth_script_exists",
    "type": "file_exists",
    "path": "server/scripts/auth.mjs"
  }
]
