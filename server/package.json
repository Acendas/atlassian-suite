{
  "name": "@acendas/atlassian-mcp",
  "version": "0.2.1",
  "description": "Acendas Atlassian Suite MCP server: unified Jira, Confluence, and Bitbucket Cloud integration.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "acendas-atlassian-mcp": "dist/server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm bundle",
    "build:tsc": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atlaskit/editor-json-transformer": "^8.31.8",
    "@atlaskit/editor-markdown-transformer": "^5.20.6",
    "adf-to-md": "^1.2.1",
    "confluence.js": "^2.1.0",
    "fastmcp": "^3.0.0",
    "jira.js": "^5.3.1",
    "turndown": "^7.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "author": {
    "name": "Acendas",
    "email": "info@acendas.ca"
  }
}
